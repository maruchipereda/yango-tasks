{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "HOST=0.0.0.0 DB_PATH=/data/yango_tasks.db UPLOAD_DIR=/data/uploads python3 app.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
